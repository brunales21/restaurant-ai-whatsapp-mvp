FROM maven:3.9.9-eclipse-temurin-21 AS build

WORKDIR /app

COPY pom.xml .
COPY src ./src

RUN mvn -DskipTests package

FROM eclipse-temurin:21-jre

WORKDIR /app

COPY --from=build /app/target/restaurant-ai-whatsapp-mvp-0.0.1-SNAPSHOT.jar app.jar

EXPOSE 8080
EXPOSE 5005

ENTRYPOINT ["java","-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005","-Dlogging.level.root=INFO","-Dlogging.level.com.restaurant=DEBUG","-Dlogging.level.org.springframework.ai=DEBUG","-Dlogging.level.org.hibernate.SQL=DEBUG","-Dlogging.level.org.hibernate.orm.jdbc.bind=TRACE","-jar","/app/app.jar"]